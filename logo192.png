<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="%PUBLIC_URL%/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0F4C35" />
    <meta name="description" content="RetailIQ — Adwuma Pa Intelligence Platform. Smart retail management for Ghanaian MSMEs by Center for Analytics Services (CAS)." />
    <meta name="keywords" content="retail, Ghana, SME, MSME, inventory, sales, POS, Accra, Makola, analytics" />
    <meta property="og:title" content="RetailIQ — Adwuma Pa" />
    <meta property="og:description" content="Smart retail intelligence for Ghanaian small businesses" />
    <meta property="og:type" content="website" />
    <link rel="apple-touch-icon" href="%PUBLIC_URL%/logo192.png" />
    <link rel="manifest" href="%PUBLIC_URL%/manifest.json" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>RetailIQ — Adwuma Pa</title>
    <style>
      #loading-screen {
        position: fixed; inset: 0; display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        background: linear-gradient(135deg, #0F4C35 0%, #1D9E75 100%);
        z-index: 9999; transition: opacity 0.5s ease;
      }
      #loading-screen.fade-out { opacity: 0; pointer-events: none; }
      .loader-logo {
        width: 64px; height: 64px; background: rgba(255,255,255,0.15);
        border-radius: 18px; display: flex; align-items: center;
        justify-content: center; margin-bottom: 20px;
        animation: pulse 1.5s ease-in-out infinite;
      }
      .loader-logo svg { width: 32px; height: 32px; }
      .loader-title { color: #fff; font-family: 'Inter', sans-serif;
        font-size: 28px; font-weight: 700; margin-bottom: 6px; }
      .loader-sub { color: #9FE1CB; font-family: 'Inter', sans-serif;
        font-size: 14px; margin-bottom: 32px; }
      .loader-bar { width: 180px; height: 3px; background: rgba(255,255,255,0.2);
        border-radius: 2px; overflow: hidden; }
      .loader-bar-fill { height: 100%; background: #9FE1CB; border-radius: 2px;
        animation: loadbar 1.2s ease-in-out forwards; }
      @keyframes pulse {
        0%,100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(159,225,203,0.4); }
        50% { transform: scale(1.05); box-shadow: 0 0 0 12px rgba(159,225,203,0); }
      }
      @keyframes loadbar { from { width: 0; } to { width: 100%; } }
    </style>
  </head>
  <body>
    <noscript>You need to enable JavaScript to run RetailIQ.</noscript>

    <!-- Loading screen -->
    <div id="loading-screen">
      <div class="loader-logo">
        <svg viewBox="0 0 24 24" fill="none" stroke="#9FE1CB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
        </svg>
      </div>
      <div class="loader-title">RetailIQ</div>
      <div class="loader-sub">Adwuma Pa · Good Business</div>
      <div class="loader-bar"><div class="loader-bar-fill"></div></div>
    </div>

    <div id="root"></div>

    <script>
      window.addEventListener('load', function() {
        setTimeout(function() {
          var screen = document.getElementById('loading-screen');
          if (screen) {
            screen.classList.add('fade-out');
            setTimeout(function() { if (screen) screen.remove(); }, 500);
          }
        }, 1400);
      });
    </script>
  </body>
</html>
